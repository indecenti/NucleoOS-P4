# ─── ESP-IDF build ─────────────────────────────────────────
/build/
# sdkconfig is generated from sdkconfig.defaults* — keep the defaults, ignore the result
sdkconfig
sdkconfig.old
sdkconfig.ci
size.json
flasher_args.json

# ─── ESP-IDF component manager ─────────────────────────────
# Regenerated from dependencies.lock + idf_component.yml — do NOT commit (182M).
# dependencies.lock IS committed (it pins versions).
/managed_components/
/main/managed_components/
/components/*/managed_components/

# ─── Firmware binaries ─────────────────────────────────────
*.bin
*.elf
*.map
*.o
*.a

# ─── Reference clones (guide repos — nested git, 1.9G) ─────
# Ignore the clones, keep our own research notes.
/reference/*
!/reference/RESEARCH.md

# ─── Python (tools/gen_*.py) ───────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ─── Vendor docs (large binary, 5M) ────────────────────────
# Comment out if you want the board manual tracked.
manual.pdf

# ─── IDE / editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*~
compile_commands.json

# ─── OS junk ───────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ─── Logs / scratch ────────────────────────────────────────
*.log
/_scratch/

# ─── ESP-IDF component-manager cache (regenerated, 93M) ────
/.cmcache/

# ─── OTA staging (regenerated by .claude/skills/ota-release) ─
/ota_serve/

# ─── Alternate/helper build dirs (verify + main build scripts) ─
/build_verify/
/build_main/
/build_*/

# ─── SD card content ───────────────────────────────────────
# The SD is a device data mirror. We KEEP the source-y parts (the web PWA, driver
# stubs, deployed WASM apps) and ignore the heavy media + generated data:
#   sd/data  = TTS voice packs, a large regenerable subset (tools/build_abc_voice.py)
#   sd/Video, sd/Music = sample media, not part of the OS.
/sd/Video/
/sd/Music/
/sd/data/

# ─── Claude Code local runtime (not project state) ─────────
.claude/scheduled_tasks.lock
.claude/settings.local.json

# ─── Third-party icon source repos (each has its own nested .git) ──────────
# Only tools/gen_icons.py reads these; the firmware uses the committed, generated
# components/nv_ui/generated/nv_icons.c. Re-clone them to regenerate icons.
/system/icons/mdi
/system/icons/flat-color

# ─── Build/debug scratch dumps + screenshots (kept on disk, not in the repo) ─
/build_out*.txt
/build_exit.txt
/_sys_*.jpg
/_hud_*.jpg
/-w

# ─── Secrets / provider keys — belt-and-suspenders (repo is PUBLIC) ─────────
# The live vault (provider API keys) is device-state on the SD, NEVER in git.
# /sd/data/ above already ignores its real home (sd/data/anima/teacher.json);
# these globs stop a key leaking if that file ever lands elsewhere.
**/teacher.json
!**/teacher.json.example
**/ai-keys.json
.env
*.env
*.env.local
secrets.json
**/*.secret
# NVS/settings backups can carry Wi-Fi credentials — keep device-state out.
*.nvb
*.nvs
settings.nvb
